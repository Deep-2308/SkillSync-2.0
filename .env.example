# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skillsync?retryWrites=true&w=majority

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI Orchestrator ──────────────────────────────────────────────────────────
PRIMARY_AI_PROVIDER=gemini
FALLBACK_AI_PROVIDER=groq

# ─── Gemini ──────────────────────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=
GEMINI_TIMEOUT_MS=20000
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# Task Specific Models
GEMINI_GENERATION_MODEL=gemini-2.5-pro
GEMINI_EVALUATION_MODEL=gemini-2.5-pro
GEMINI_PROJECT_ANALYSIS_MODEL=gemini-2.5-pro

# Task Specific Thinking Mode
GEMINI_GENERATION_THINKING=true
GEMINI_EVALUATION_THINKING=false
GEMINI_PROJECT_ANALYSIS_THINKING=false

# ─── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=8000
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=2048

# ─── Cloudinary ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Resend (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

