# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skillsync?retryWrites=true&w=majority

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google GenAI (Gemini) ───────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Resend (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Anthropic generation settings (optional; defaults shown) ────────────────
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TEMPERATURE=0.85
ANTHROPIC_MAX_TOKENS=900
ANTHROPIC_TIMEOUT_MS=15000
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_RETRY_BASE_MS=500
